{
  "name": "Driver",
  "type": "object",
  "properties": {
    "driver_id": {
      "type": "string",
      "description": "Unique driver identifier e.g. DRV-001"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "linked_user_email": {
      "type": "string",
      "description": "Email of the User account for this driver (portal login)"
    },
    "license_number": {
      "type": "string"
    },
    "license_expiry": {
      "type": "string",
      "format": "date"
    },
    "license_status": {
      "type": "string",
      "enum": [
        "valid",
        "expiring_soon",
        "expired",
        "suspended"
      ],
      "default": "valid"
    },
    "insurance_status": {
      "type": "string",
      "enum": [
        "current",
        "expiring_soon",
        "expired",
        "not_required"
      ],
      "default": "current"
    },
    "insurance_expiry": {
      "type": "string",
      "format": "date"
    },
    "availability": {
      "type": "string",
      "enum": [
        "available",
        "on_duty",
        "off_duty",
        "on_leave",
        "unavailable"
      ],
      "default": "available"
    },
    "shift_schedule": {
      "type": "string",
      "description": "e.g. Mon-Fri 6am-4pm"
    },
    "active_days": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Days driver is scheduled: monday, tuesday, wednesday, thursday, friday, saturday, sunday"
    },
    "assigned_vehicle_id": {
      "type": "string"
    },
    "assigned_vehicle_name": {
      "type": "string"
    },
    "backup_vehicle_eligible": {
      "type": "boolean",
      "default": false
    },
    "backup_driver_role": {
      "type": "string",
      "enum": [
        "none",
        "primary_backup",
        "secondary_backup",
        "on_call"
      ],
      "default": "none",
      "description": "Role when serving as backup for another driver"
    },
    "preferred_client_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs of clients preferably assigned to this driver"
    },
    "service_area": {
      "type": "string"
    },
    "territory_zones": {
      "type": "string",
      "description": "Specific zones or neighborhoods covered"
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "admin_notes": {
      "type": "string",
      "description": "Internal admin notes not visible to driver"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "suspended"
      ],
      "default": "active"
    },
    "emergency_contact_name": {
      "type": "string"
    },
    "emergency_contact_phone": {
      "type": "string"
    },
    "total_rides_completed": {
      "type": "number",
      "default": 0
    },
    "on_time_rate": {
      "type": "number",
      "description": "Percentage 0-100",
      "default": 100
    },
    "incident_count": {
      "type": "number",
      "default": 0
    },
    "cancellation_count": {
      "type": "number",
      "default": 0
    },
    "hire_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "first_name",
    "last_name",
    "phone"
  ]
}